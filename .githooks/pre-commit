#!/usr/bin/env bash
# GlassWorm Defense: Detect invisible Unicode characters in source files
# Blocks commits containing Unicode variation selectors (U+FE00-FE0F),
# supplementary PUA characters (U+E0100-E01EF), zero-width joiners/spaces,
# and other invisible characters commonly used in supply-chain attacks.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Source file extensions to scan
EXTENSIONS="py|js|ts|tsx|jsx|rs|sh|toml|yml|yaml|json|cfg|ini|sql"

# Get staged files matching our extensions
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.($EXTENSIONS)$" || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_ISSUES=0

for FILE in $STAGED_FILES; do
    if [ ! -f "$FILE" ]; then
        continue
    fi

    # Check for invisible Unicode characters:
    # - U+200B Zero Width Space
    # - U+200C Zero Width Non-Joiner
    # - U+200D Zero Width Joiner
    # - U+2060 Word Joiner
    # - U+FEFF BOM / Zero Width No-Break Space
    # - U+FE00-FE0F Variation Selectors
    # - U+00AD Soft Hyphen
    # - U+034F Combining Grapheme Joiner
    # - U+2028 Line Separator
    # - U+2029 Paragraph Separator
    # - U+202A-202E Bidi control characters
    # - U+2066-2069 Bidi isolate characters
    # - U+E0100-E01EF Variation Selectors Supplement
    MATCHES=$(grep -Pn '[\x{200B}\x{200C}\x{200D}\x{2060}\x{FEFF}\x{FE00}-\x{FE0F}\x{00AD}\x{034F}\x{2028}\x{2029}\x{202A}-\x{202E}\x{2066}-\x{2069}\x{E0100}-\x{E01EF}]' "$FILE" 2>/dev/null || true)

    if [ -n "$MATCHES" ]; then
        echo -e "${RED}BLOCKED:${NC} Invisible Unicode characters detected in ${YELLOW}$FILE${NC}"
        echo "$MATCHES" | head -5
        FOUND_ISSUES=1
    fi

    # Also check for the known GlassWorm IOC marker
    if grep -q "lzcdrtfxyqiplpd" "$FILE" 2>/dev/null; then
        echo -e "${RED}CRITICAL:${NC} GlassWorm IOC marker found in ${YELLOW}$FILE${NC}"
        FOUND_ISSUES=1
    fi

    # Check for suspicious eval+decode patterns in JS/TS/PY files
    if echo "$FILE" | grep -qE '\.(js|ts|tsx|jsx|py)$'; then
        EVAL_MATCHES=$(grep -Pn 'eval\s*\(.*fromCharCode|eval\s*\(.*\\x[0-9a-fA-F]|exec\s*\(.*decode\s*\(' "$FILE" 2>/dev/null || true)
        if [ -n "$EVAL_MATCHES" ]; then
            echo -e "${YELLOW}WARNING:${NC} Suspicious eval/exec+decode pattern in ${YELLOW}$FILE${NC}"
            echo "$EVAL_MATCHES" | head -3
            FOUND_ISSUES=1
        fi
    fi
done

if [ "$FOUND_ISSUES" -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit blocked by GlassWorm defense hook.${NC}"
    echo -e "If these are intentional (e.g., malware analysis test data), use: git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}GlassWorm defense: No invisible Unicode or supply-chain IOCs detected.${NC}"
exit 0
